# xtty example configuration
#
# Copy this file to:   ~/.config/xtty/config
#   (or $XDG_CONFIG_HOME/xtty/config if XDG_CONFIG_HOME is set)
# then edit the values below. xtty reads it once at launch.
#
# Format: one `key = value` per line. `#` starts a comment; blank lines are
# ignored; surrounding whitespace is trimmed. Unknown keys are ignored, and any
# recognized key with an invalid value falls back to its default (and is logged).
# Every line below shows xtty's built-in DEFAULT — uncomment and change to override.

# Font family. Omit (or leave blank) to use the system monospaced font (SF Mono).
# Any installed monospaced family works, e.g. "Menlo", "JetBrains Mono".
# font-family =

# Base font point size (clamped to 6...72). Cmd +/- adjust it live; Cmd 0 resets
# to this value. Live changes are NOT written back to this file.
# font-size = 13

# Color theme. Built-ins: "dark" (default) or "light". Unknown names fall back
# to dark.
# theme = dark

# Scrollback retention, in lines (clamped to 0...100000). Bounded by design —
# there is no "unlimited". Larger values use more memory.
# scrollback = 10000

# Whether the Option key sends Meta (true) or composes characters like é (false).
# Accepts true/false, yes/no, on/off, 1/0.
# option-as-meta = true

# --- Keybindings ---
#
# Pick a preset, then override individual actions as needed. Default: iterm.
#   iterm    Cmd+D split right, Cmd+Shift+D split down, Cmd+Opt+arrows focus,
#            Cmd+T new tab, Cmd+N new window, Cmd+W close pane
#   ghostty  same, but pane focus on Cmd+[ (prev) / Cmd+] (next)
# keybind-style = iterm
#
# Per-action overrides. A chord is one or more modifiers + exactly one key,
# joined by "+", e.g. "cmd+shift+d".
#   modifiers: cmd, ctrl, opt (alt), shift
#   keys:      letters/digits, a single symbol, the arrows left/right/up/down,
#              or the names plus, minus, equal, space
# Actions (key = keybind-<action>): split-right, split-down, focus-left,
# focus-right, focus-up, focus-down, new-tab, new-window, close, font-increase,
# font-decrease, font-reset, find. An invalid value keeps the preset's binding.
# keybind-split-down = cmd+shift+d
# keybind-focus-left = cmd+opt+left

# --- Quick terminal (the "quake" drop-down) ---
#
# A scratch terminal summoned by a global hotkey from anywhere, even when xtty is
# not focused. Off by default. When on, you MUST also set a hotkey, or it stays
# disabled (a reserved combo that the system rejects also disables it, logged).
# quick-terminal = false
#
# The global hotkey. Same chord grammar as keybindings (modifiers + one key),
# using a physical key by name — e.g. "grave" is the ` key regardless of layout.
# The `fn` key is not supported. Example: toggle on Ctrl+Option+Backtick.
# quick-terminal-hotkey = ctrl+opt+grave

# --- Shell integration (OSC 133 command blocks + OSC 7 cwd) ---
#
# xtty automatically integrates with zsh so it can track command boundaries and
# the working directory (new splits open where you are; a future sidebar shows
# per-command status). It does this by pointing ZDOTDIR at a bundled directory
# whose .zshenv restores your real ZDOTDIR and sources your config first, then
# installs additive precmd/preexec hooks — your dotfiles, prompt (powerlevel10k /
# starship), .zprofile and .zshrc all load normally. There is nothing to set up.
#
# If a system /etc/zshenv overrides ZDOTDIR (rare) the automatic redirect can't
# apply; enable integration manually by sourcing the bundled hooks from your
# ~/.zshrc:
#   source "/Applications/xtty.app/Contents/Resources/shell-integration/zsh/xtty-integration"
# (Adjust the path if xtty is installed elsewhere.) bash/fish are not yet
# auto-integrated.

# --- Close confirmation ---
#
# Whether to confirm before closing a pane that has a running foreground job
# (true/false, yes/no, on/off, 1/0). Default true.
# confirm-close = true

# --- Profiles (named setting bundles) ---
#
# Everything ABOVE this first section header is the "base" profile. A
# `[profile "name"]` header starts a named profile that INHERITS the base and
# overrides only the keys it sets. A config with no profile sections behaves
# exactly as before (it is entirely the base profile) — profiles are opt-in.
#
# Appearance keys (font-family, font-size, theme, scrollback, option-as-meta)
# work in any profile. Profiles add three LAUNCH keys:
#   command    A command to run instead of a plain login shell. It runs THROUGH
#              your login + interactive shell (`$SHELL -l -i -c '<command>'`), so
#              bare names resolve against your real PATH and dotfiles, and shell
#              syntax (pipes, globs, ~) works. Omit it for a normal login shell.
#   cwd        Working directory to start in. `~` and `$HOME` are expanded; a
#              missing directory is logged and falls back to the default.
#   env-<NAME> Set an environment variable (repeatable; case-sensitive name).
#              `env-PATH` is ignored — the login shell builds PATH.
#
# default-profile (base only) picks the profile new tabs/windows use; the menu
# "Terminal ▸ New Tab with Profile" opens a chosen one. A split inherits the
# focused pane's profile. The quick terminal always uses base appearance + a
# plain login shell. Config is read once at launch (relaunch to apply edits).
#
# default-profile = work
#
# [profile "work"]
# theme = light
# cwd = ~/src/work
# env-EDITOR = nvim
#
# [profile "ssh-box"]
# command = ssh box
