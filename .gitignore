# Claude Code local files — ignored EXCEPT this project's own committed tooling:
# the /xtty: command(s) and the xtty-* skill(s). Machine-local settings/locks and
# the openspec-generated commands/skills stay out of git. (Re-include level by
# level — git can't un-ignore a child of an ignored directory.)
.claude/*
!.claude/commands/
.claude/commands/*
!.claude/commands/xtty/
!.claude/skills/
.claude/skills/*
!.claude/skills/xtty-*/

# Generated Xcode project (produced from project.yml via `xcodegen generate`)
xtty.xcodeproj/

# Swift Package Manager build artifacts
.build/
XttyCore/.build/
.swiftpm/
XttyCore/.swiftpm/

# xcodebuild DerivedData — the Makefile builds into ./build (-derivedDataPath build)
/build/

# SwiftTerm patched checkout — gitignored build infra, reconstituted by
# scripts/bootstrap-swiftterm.sh from patches/swiftterm/UPSTREAM_CONFIG.sh.
# (Playwright-style: track the patch + pin + script, not the upstream tree.)
external/SwiftTerm/

# macOS
.DS_Store
